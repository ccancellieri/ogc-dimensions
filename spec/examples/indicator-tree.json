{
  "type": "Collection",
  "id": "faostat-food-security",
  "stac_version": "1.0.0",
  "stac_extensions": [
    "https://stac-extensions.github.io/datacube/v2.3.0/schema.json",
    "https://stac-extensions.github.io/language/v1.0.0/schema.json"
  ],
  "language": {"code": "en", "name": "English"},
  "languages": [
    {"code": "fr", "name": "Français",  "alternate": "French"},
    {"code": "ar", "name": "العربية",   "alternate": "Arabic", "dir": "rtl"},
    {"code": "es", "name": "Español",   "alternate": "Spanish"},
    {"code": "zh", "name": "中文",       "alternate": "Chinese"}
  ],
  "title": "FAO FAOSTAT Food Security Indicators",
  "description": "FAOSTAT Suite of Food Security Indicators — multi-dimensional data covering food availability, access, utilization, and stability across 195 countries.",
  "license": "proprietary",
  "extent": {
    "spatial": {
      "bbox": [
        [
          -180,
          -90,
          180,
          90
        ]
      ]
    },
    "temporal": {
      "interval": [
        [
          "1961-01-01T00:00:00Z",
          null
        ]
      ]
    }
  },
  "links": [],
  "cube:dimensions": {
    "x": {
      "type": "spatial",
      "axis": "x",
      "extent": [
        -180,
        180
      ],
      "reference_system": 4326
    },
    "y": {
      "type": "spatial",
      "axis": "y",
      "extent": [
        -90,
        90
      ],
      "reference_system": 4326
    },
    "time": {
      "type": "temporal",
      "extent": [
        "1961-01-01T00:00:00Z",
        null
      ],
      "step": "P1Y",
      "unit": "year"
    },
    "indicator": {
      "type": "nominal",
      "description": "Statistical indicator dimension. Recursive hierarchy: each indicator carries a parent_code field referencing its parent indicator or group. Root members (domains) have parent_code = null. Clients retrieve all root indicators, then navigate children via /children. This mirrors SKOS concept scheme navigation (skos:narrower) as a RESTful paginated API.",
      "hierarchy": {
        "strategy": "recursive",
        "parent_property": "parent_code",
        "root_filter": "parent_code IS NULL",
        "depth": 4
      },
      "generator": {
        "type": "https://www.fao.org/faostat/generators/indicator/openapi.json",
        "api": "https://www.fao.org/faostat/generators/indicator/openapi.json",
        "config": {},
        "parameters": {
          "type": "object",
          "properties": {
            "domain": {
              "type": "string",
              "description": "Restrict to a specific top-level domain (e.g., 'QC' for Food Security)."
            },
            "parent": {
              "type": "string",
              "description": "Return only direct children of this indicator code."
            },
            "language": {
              "type": "string",
              "description": "RFC 5646 Language-Tag selecting the label language and sort collation (e.g. 'fr', 'ar', 'zh'). Overrides Accept-Language header. Defaults to 'en'."
            },
            "sort_by": {
              "type": "string",
              "enum": ["code", "label"],
              "description": "Field to sort members by. 'label' uses locale-aware collation for the negotiated language."
            },
            "sort_dir": {
              "type": "string",
              "enum": ["asc", "desc"],
              "default": "asc",
              "description": "Sort direction."
            }
          }
        },
        "output": {
          "type": "object",
          "required": ["code", "label", "parent_code"],
          "properties": {
            "code": {
              "type": "string",
              "description": "Indicator code (e.g., 'FS-AVL-DES')."
            },
            "label": {
              "type": "string",
              "description": "Indicator name in the negotiated language (default: English)."
            },
            "labels": {
              "type": "object",
              "description": "Indicator name in all available languages. Keys are RFC 5646 Language-Tags. Clients SHOULD prefer labels[negotiated_lang] over 'label'.",
              "additionalProperties": {"type": "string"},
              "example": {
                "en": "Dietary Energy Supply",
                "fr": "Approvisionnement en énergie alimentaire",
                "ar": "إمدادات الطاقة الغذائية",
                "es": "Suministro de energía alimentaria",
                "zh": "膳食能量供应"
              }
            },
            "has_children": {
              "type": "boolean",
              "description": "True if this indicator has child indicators. Allows tree-rendering clients to show expand controls without a /children round-trip."
            },
            "parent_code": {
              "type": ["string", "null"],
              "description": "Parent indicator code; null for domain-level root indicators. Analogous to skos:broader."
            },
            "unit": {
              "type": "string",
              "description": "Unit of measure (e.g., 'kcal/person/day')."
            },
            "description": {
              "type": "string",
              "description": "Long-form description of the indicator."
            }
          }
        },
        "invertible": false,
        "search": ["exact", "like"],
        "on_invalid": "accept",
        "hierarchical": true,
        "language_support": [
          {"code": "en", "name": "English"},
          {"code": "fr", "name": "Français",  "alternate": "French"},
          {"code": "ar", "name": "العربية",   "alternate": "Arabic", "dir": "rtl"},
          {"code": "es", "name": "Español",   "alternate": "Spanish"},
          {"code": "zh", "name": "中文",       "alternate": "Chinese"}
        ]
      },
      "href": "https://data.review.fao.org/geospatial/v2/api/tools/dimensions/faostat-indicators/members?limit=5"
    }
  }
}
