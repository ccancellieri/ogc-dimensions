{
  "type": "Collection",
  "id": "srtm-elevation-bands",
  "title": "SRTM Elevation Bands",
  "description": "SRTM digital elevation model classified into 100m elevation bands.",
  "cube:dimensions": {
    "elevation": {
      "type": "other",
      "description": "Elevation bands (meters above sea level)",
      "extent": [0, 5000],
      "generator": {
        "type": "integer-range",
        "parameters": {
          "type": "object",
          "properties": {
            "step": {"type": "integer", "const": 100}
          },
          "required": ["step"]
        },
        "output": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5000
        },
        "invertible": true,
        "search": ["exact", "range"],
        "on_invalid": "reject"
      },
      "unit": "m",
      "size": 51,
      "href": "https://data.review.fao.org/geospatial/v2/api/tools/dimensions/integer-range/generate?limit=5"
    },
    "x": {
      "type": "spatial",
      "axis": "x",
      "extent": [-180, 180],
      "reference_system": 4326
    },
    "y": {
      "type": "spatial",
      "axis": "y",
      "extent": [-60, 60],
      "reference_system": 4326
    }
  }
}
