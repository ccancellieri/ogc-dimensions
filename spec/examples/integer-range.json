{
  "type": "Collection",
  "id": "srtm-elevation-bands",
  "stac_version": "1.0.0",
  "stac_extensions": [
    "https://stac-extensions.github.io/datacube/v2.3.0/schema.json"
  ],
  "title": "SRTM Elevation Bands",
  "description": "SRTM digital elevation model classified into 100 m elevation bands (0–5000 m). Demonstrates the Invertible conformance level: any raw elevation value maps deterministically to its enclosing band via /inverse.",
  "license": "proprietary",
  "extent": {
    "spatial": {"bbox": [[-180, -60, 180, 60]]},
    "temporal": {"interval": [["2000-02-11T00:00:00Z", "2000-02-22T23:59:59Z"]]}
  },
  "links": [
    {"rel": "self", "href": "#", "type": "application/json"},
    {"rel": "root", "href": "#", "type": "application/json"}
  ],
  "cube:dimensions": {
    "x": {
      "type": "spatial", "axis": "x",
      "extent": [-180, 180], "reference_system": 4326
    },
    "y": {
      "type": "spatial", "axis": "y",
      "extent": [-60, 60], "reference_system": 4326
    },
    "elevation": {
      "type": "other",
      "description": "Elevation bands (metres above sea level). 100 m step from 0 to 5000 m produces 51 bands.",
      "extent": [0, 5000],
      "unit": "m",
      "size": 51,
      "href": "https://data.review.fao.org/geospatial/v2/api/tools/dimensions/elevation-bands/items?limit=5",
      "provider": {
        "type": "integer-range",
        "href": "https://data.review.fao.org/geospatial/v2/api/tools/dimensions/elevation-bands"
      }
    }
  },
  "cube:variables": {
    "elevation": {
      "dimensions": ["y", "x"],
      "type": "data",
      "unit": "m",
      "description": "Digital elevation model value in metres."
    }
  }
}
