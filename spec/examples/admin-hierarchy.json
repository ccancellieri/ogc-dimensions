{
  "type": "Collection",
  "id": "gaul-admin-boundaries",
  "stac_version": "1.0.0",
  "stac_extensions": [
    "https://stac-extensions.github.io/datacube/v2.3.0/schema.json"
  ],
  "title": "GAUL Global Administrative Boundaries",
  "description": "FAO Global Administrative Unit Layers (GAUL) — administrative boundaries at country, ADM1, and ADM2 levels for 195 countries.",
  "license": "proprietary",
  "extent": {
    "spatial": {
      "bbox": [
        [
          -180,
          -90,
          180,
          90
        ]
      ]
    },
    "temporal": {
      "interval": [
        [
          "2015-01-01T00:00:00Z",
          null
        ]
      ]
    }
  },
  "links": [],
  "cube:dimensions": {
    "x": {
      "type": "spatial",
      "axis": "x",
      "extent": [
        -180,
        180
      ],
      "reference_system": 4326
    },
    "y": {
      "type": "spatial",
      "axis": "y",
      "extent": [
        -90,
        90
      ],
      "reference_system": 4326
    },
    "admin": {
      "type": "nominal",
      "description": "Administrative boundary dimension. Three-level hierarchy: Country (L0), ADM1 sub-national unit (L1), ADM2 district (L2). Leveled strategy: hierarchy is defined by level rules, not by parent fields stored on members. Clients navigate via /children endpoint.",
      "hierarchy": {
        "strategy": "leveled",
        "levels": [
          {
            "id": "L0",
            "label": "Country",
            "size": 195,
            "member_id_property": "iso_code",
            "parameters": {
              "level": 0
            },
            "href": "https://data.review.fao.org/geospatial/v2/api/tools/dimensions/world-admin/members?level=0&limit=5"
          },
          {
            "id": "L1",
            "label": "ADM1",
            "size": 3469,
            "parent_level": "L0",
            "member_id_property": "adm1_code",
            "parent_id_property": "iso_code",
            "parameters": {
              "level": 1
            },
            "href": "https://data.review.fao.org/geospatial/v2/api/tools/dimensions/world-admin/members?level=1&limit=5"
          },
          {
            "id": "L2",
            "label": "ADM2",
            "size": 46031,
            "parent_level": "L1",
            "member_id_property": "adm2_code",
            "parent_id_property": "adm1_code",
            "parameters": {
              "level": 2
            },
            "href": "https://data.review.fao.org/geospatial/v2/api/tools/dimensions/world-admin/members?level=2&limit=5"
          }
        ]
      },
      "generator": {
        "type": "leveled-tree",
        "parameters": {
          "type": "object",
          "properties": {
            "level": {
              "type": "integer",
              "enum": [
                0,
                1,
                2
              ],
              "description": "Hierarchy level to generate members for. 0=Country, 1=ADM1, 2=ADM2."
            },
            "parent": {
              "type": "string",
              "description": "Filter members to children of this parent member code."
            }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string",
              "description": "Member identifier (iso_code, adm1_code, or adm2_code depending on level)"
            },
            "label": {
              "type": "string",
              "description": "Human-readable name"
            },
            "level": {
              "type": "integer",
              "description": "Hierarchy level (0, 1, or 2)"
            },
            "iso_code": {
              "type": "string",
              "description": "ISO 3166-1 alpha-3 country code (present on all levels)"
            }
          },
          "required": [
            "code",
            "label",
            "level"
          ]
        },
        "invertible": false,
        "search": [
          "exact",
          "like"
        ],
        "hierarchical": true
      },
      "href": "https://data.review.fao.org/geospatial/v2/api/tools/dimensions/world-admin/members?level=0&limit=5"
    }
  }
}
