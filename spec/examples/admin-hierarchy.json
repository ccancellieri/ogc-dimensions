{
  "type": "Collection",
  "id": "gaul-admin-boundaries",
  "stac_version": "1.0.0",
  "stac_extensions": [
    "https://stac-extensions.github.io/datacube/v2.3.0/schema.json",
    "https://stac-extensions.github.io/language/v1.0.0/schema.json"
  ],
  "language": {
    "code": "en",
    "name": "English"
  },
  "languages": [
    {"code": "fr", "name": "Français",  "alternate": "French"},
    {"code": "ar", "name": "العربية",   "alternate": "Arabic",  "dir": "rtl"},
    {"code": "es", "name": "Español",   "alternate": "Spanish"},
    {"code": "zh", "name": "中文",       "alternate": "Chinese"}
  ],
  "title": "GAUL Global Administrative Boundaries",
  "description": "FAO Global Administrative Unit Layers (GAUL) — administrative boundaries at country, ADM1, and ADM2 levels for 195 countries.",
  "license": "proprietary",
  "extent": {
    "spatial": {
      "bbox": [
        [
          -180,
          -90,
          180,
          90
        ]
      ]
    },
    "temporal": {
      "interval": [
        [
          "2015-01-01T00:00:00Z",
          null
        ]
      ]
    }
  },
  "links": [],
  "cube:dimensions": {
    "x": {
      "type": "spatial",
      "axis": "x",
      "extent": [
        -180,
        180
      ],
      "reference_system": 4326
    },
    "y": {
      "type": "spatial",
      "axis": "y",
      "extent": [
        -90,
        90
      ],
      "reference_system": 4326
    },
    "admin": {
      "type": "nominal",
      "description": "Administrative boundary dimension. Three-level hierarchy: Country (L0), ADM1 sub-national unit (L1), ADM2 district (L2). Leveled strategy: hierarchy is defined by level rules, not by parent fields stored on members. Clients navigate via /children endpoint.",
      "hierarchy": {
        "strategy": "leveled",
        "levels": [
          {
            "id": "L0",
            "label": "Country",
            "labels": {"en": "Country", "fr": "Pays", "ar": "دولة", "es": "País", "zh": "国家"},
            "size": 195,
            "member_id_property": "iso_code",
            "parameters": {
              "level": 0
            },
            "href": "https://data.review.fao.org/geospatial/v2/api/tools/dimensions/world-admin/members?level=0&limit=5"
          },
          {
            "id": "L1",
            "label": "ADM1",
            "labels": {"en": "ADM1", "fr": "Région / État", "ar": "المستوى 1", "es": "ADM1", "zh": "一级行政区"},
            "size": 3469,
            "parent_level": "L0",
            "member_id_property": "adm1_code",
            "parent_id_property": "iso_code",
            "parameters": {
              "level": 1
            },
            "href": "https://data.review.fao.org/geospatial/v2/api/tools/dimensions/world-admin/members?level=1&limit=5"
          },
          {
            "id": "L2",
            "label": "ADM2",
            "labels": {"en": "ADM2", "fr": "District / Département", "ar": "المستوى 2", "es": "ADM2", "zh": "二级行政区"},
            "size": 46031,
            "parent_level": "L1",
            "member_id_property": "adm2_code",
            "parent_id_property": "adm1_code",
            "parameters": {
              "level": 2
            },
            "href": "https://data.review.fao.org/geospatial/v2/api/tools/dimensions/world-admin/members?level=2&limit=5"
          }
        ]
      },
      "generator": {
        "type": "leveled-tree",
        "config": {},
        "parameters": {
          "type": "object",
          "properties": {
            "level": {
              "type": "integer",
              "enum": [0, 1, 2],
              "description": "Hierarchy level to generate members for. 0=Country, 1=ADM1, 2=ADM2."
            },
            "parent": {
              "type": "string",
              "description": "Filter members to children of this parent member code."
            },
            "language": {
              "type": "string",
              "description": "RFC 5646 Language-Tag (or Accept-Language priority list) selecting the label language and sort collation. E.g. 'fr', 'ar', 'zh'. Overrides the Accept-Language header. When omitted, the default language (en) is used."
            },
            "sort_by": {
              "type": "string",
              "enum": ["code", "label"],
              "description": "Output field to sort members by. 'label' uses locale-aware collation for the negotiated language."
            },
            "sort_dir": {
              "type": "string",
              "enum": ["asc", "desc"],
              "default": "asc",
              "description": "Sort direction. Used with sort_by."
            }
          }
        },
        "output": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string",
              "description": "Member identifier (iso_code, adm1_code, or adm2_code depending on level)."
            },
            "label": {
              "type": "string",
              "description": "Human-readable name in the negotiated language (or default language if no language was requested)."
            },
            "labels": {
              "type": "object",
              "description": "Human-readable names in all available languages. Keys are RFC 5646 Language-Tags. Clients SHOULD prefer labels[negotiated_lang] over the 'label' field.",
              "additionalProperties": {"type": "string"},
              "example": {"en": "France", "fr": "France", "ar": "فرنسا", "es": "Francia", "zh": "法国"}
            },
            "has_children": {
              "type": "boolean",
              "description": "True if this member has at least one child in the hierarchy. Allows tree-rendering clients to show expand controls without a /children round-trip."
            },
            "level": {
              "type": "integer",
              "description": "Hierarchy level (0=Country, 1=ADM1, 2=ADM2)."
            },
            "iso_code": {
              "type": "string",
              "description": "ISO 3166-1 alpha-3 country code (present on all levels)."
            }
          },
          "required": ["code", "label", "level"]
        },
        "invertible": false,
        "search": ["exact", "like"],
        "hierarchical": true,
        "language_support": [
          {"code": "en", "name": "English"},
          {"code": "fr", "name": "Français",  "alternate": "French"},
          {"code": "ar", "name": "العربية",   "alternate": "Arabic",  "dir": "rtl"},
          {"code": "es", "name": "Español",   "alternate": "Spanish"},
          {"code": "zh", "name": "中文",       "alternate": "Chinese"}
        ]
      },
      "href": "https://data.review.fao.org/geospatial/v2/api/tools/dimensions/world-admin/members?level=0&limit=5"
    }
  }
}
