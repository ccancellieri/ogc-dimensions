{
  "pentadal_monthly_example": {
    "type": "Collection",
    "id": "chirps-pentadal-precipitation",
    "description": "Month-based pentadal (72 periods/year). Each month has 6 pentads of 5 days; P6 absorbs remaining days (26-end). Used by CHIRPS, CDT, FAO.",
    "cube:dimensions": {
      "time": {
        "type": "temporal",
        "extent": [
          "2000-01-01T00:00:00Z",
          "2024-12-31T23:59:59Z"
        ],
        "generator": {
          "type": "pentadal-monthly",
          "output": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "YYYY-Pnn (nn=01..72)"
              },
              "start": {
                "type": "string",
                "format": "date"
              },
              "end": {
                "type": "string",
                "format": "date"
              }
            },
            "required": [
              "code",
              "start",
              "end"
            ]
          },
          "invertible": true,
          "search": [
            "exact",
            "range",
            "like"
          ],
          "on_invalid": "reject"
        },
        "step": null,
        "unit": "pentad",
        "size": 1800,
        "href": "https://data.review.fao.org/geospatial/v2/api/tools/dimensions/pentadal-monthly/members?limit=5"
      }
    }
  },
  "pentadal_annual_example": {
    "type": "Collection",
    "id": "gpcp-pentadal-precipitation",
    "description": "Year-based pentadal (73 periods/year). Consecutive 5-day periods starting Jan 1. Period 73 has 5 or 6 days (leap year). Used by GPCP, CPC/NOAA.",
    "cube:dimensions": {
      "time": {
        "type": "temporal",
        "extent": [
          "2000-01-01T00:00:00Z",
          "2024-12-31T23:59:59Z"
        ],
        "generator": {
          "type": "pentadal-annual",
          "output": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "YYYY-Ann (nn=01..73)"
              },
              "start": {
                "type": "string",
                "format": "date"
              },
              "end": {
                "type": "string",
                "format": "date"
              }
            },
            "required": [
              "code",
              "start",
              "end"
            ]
          },
          "invertible": true,
          "search": [
            "exact",
            "range",
            "like"
          ]
        },
        "step": null,
        "unit": "pentad",
        "size": 1825,
        "href": "https://data.review.fao.org/geospatial/v2/api/tools/dimensions/pentadal-annual/members?limit=5"
      }
    }
  }
}
